# .gitignore for Extractor Node.js

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment
.env
.env.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Temporary files
.temp/
tmp/
eval/workdir/
eval/runs/

# Ignorar todos los archivos .sqlite exclusivamente en la raíz
/*.sqlite

# Ignorar datos de LanceDB en cualquier nivel
lancedb/
