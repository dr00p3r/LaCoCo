{
  "compilerOptions": {
    // Diseño de archivos
    "rootDir": "./src",
    "outDir": "./dist",

    // ESM + NodeNext: resuelve imports con extensiones explícitas
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    // Tipos
    "lib": ["ES2022"],
    "types": ["node"],

    // Salidas adicionales
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Verificación estricta
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    // Compatibilidad
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
