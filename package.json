{
  "name": "@joru/lacoco",
  "version": "1.0.1",
  "description": "Recuperador local de contexto para grandes bases de código TypeScript/JavaScript",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "lacoco": "./dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "docs/cli.md",
    "docs/mcp.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc --project tsconfig.json && node scripts/copy-migrations.mjs",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit && tsc --project eval/tsconfig.json",
    "eval:check-manifests": "node --import tsx eval/scripts/lib/load-manifests.ts",
    "eval:import:swe-polybench": "node --import tsx eval/scripts/import-swe-polybench.ts",
    "eval:import:multi-swe-bench": "node --import tsx eval/scripts/import-multi-swe-bench.ts",
    "eval:enrich:gold-symbols": "node --import tsx eval/scripts/enrich-gold-symbols.ts",
    "eval:reconcile:gold-symbols": "node --import tsx eval/scripts/reconcile-gold-symbols.ts",
    "eval:build:bench10-splits": "node --import tsx eval/scripts/build-bench10-splits.ts",
    "eval:prepare": "node --import tsx eval/scripts/prepare-repos.ts",
    "eval:index": "node --import tsx eval/scripts/index-repos.ts",
    "eval:retrieve:deterministic": "node --import tsx eval/scripts/deterministic-retrieve.ts",
    "eval:retrieval": "node --import tsx eval/scripts/run-retrieval.ts",
    "eval:grounding:profiles": "node --import tsx eval/scripts/build-grounding-profiles.ts",
    "eval:metrics:retrieval": "node --import tsx eval/scripts/compute-retrieval-metrics.ts",
    "eval:benchmark:doctor": "node --import tsx eval/scripts/benchmark-doctor.ts",
    "eval:metrics:semantic-profile": "node --import tsx eval/scripts/compute-semantic-profile-metrics.ts",
    "eval:generation": "node --import tsx eval/scripts/run-generation.ts",
    "eval:regrade": "node --import tsx eval/scripts/regrade-tests.ts",
    "eval:hallucination": "node --import tsx eval/scripts/analyze-hallucinations.ts",
    "eval:metrics:generation": "node --import tsx eval/scripts/compute-generation-metrics.ts",
    "eval:compare:strategies": "node --import tsx eval/scripts/compare-strategies.ts",
    "eval:gold:worksheet": "node --import tsx eval/scripts/create-ground-truth-worksheet.ts",
    "eval:gold:validate": "node --import tsx eval/scripts/validate-ground-truth.ts",
    "test": "vitest run --config vitest.lacoco.config.ts",
    "test:watch": "vitest --config vitest.lacoco.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm run test:integration",
    "test:coverage": "vitest run --config vitest.coverage.config.ts"
  },
  "keywords": [
    "typescript",
    "ast",
    "static-analysis",
    "cli",
    "graph"
  ],
  "author": "",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "gpt-tokenizer": "^3.4.0",
    "ts-morph": "^27.0.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "protobufjs": "^7.5.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  }
}
