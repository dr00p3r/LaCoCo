{
  "name": "tensor-extractor",
  "version": "1.0.0",
  "description": "Herramienta CLI de análisis estático de código TypeScript con grafos en SQLite",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "lacoco": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc --project tsconfig.json && node scripts/copy-migrations.mjs",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit && tsc --project eval/tsconfig.json",
    "eval:check-manifests": "node --import tsx eval/scripts/lib/load-manifests.ts",
    "eval:prepare": "node --import tsx eval/scripts/prepare-repos.ts",
    "eval:index": "node --import tsx eval/scripts/index-repos.ts",
    "eval:retrieve:deterministic": "node --import tsx eval/scripts/deterministic-retrieve.ts",
    "eval:retrieval": "node --import tsx eval/scripts/run-retrieval.ts",
    "eval:metrics:retrieval": "node --import tsx eval/scripts/compute-retrieval-metrics.ts",
    "eval:metrics:semantic-profile": "node --import tsx eval/scripts/compute-semantic-profile-metrics.ts",
    "eval:generation": "node --import tsx eval/scripts/run-generation.ts",
    "eval:hallucination": "node --import tsx eval/scripts/analyze-hallucinations.ts",
    "eval:metrics:generation": "node --import tsx eval/scripts/compute-generation-metrics.ts",
    "eval:gold:worksheet": "node --import tsx eval/scripts/create-ground-truth-worksheet.ts",
    "eval:gold:validate": "node --import tsx eval/scripts/validate-ground-truth.ts",
    "test": "vitest run --config vitest.lacoco.config.ts",
    "test:watch": "vitest --config vitest.lacoco.config.ts"
  },
  "keywords": [
    "typescript",
    "ast",
    "static-analysis",
    "cli",
    "graph"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "gpt-tokenizer": "^3.4.0",
    "ts-morph": "^27.0.2"
  },
  "overrides": {
    "protobufjs": "^7.5.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  }
}
