--- /dev/null
+++ b/changelog_unreleased/javascript/9850.md
@@ -0,0 +1,31 @@
+#### Fix extra semicolon added to ignored directives (#9850 by @fisker)
+
+<!-- prettier-ignore -->
+```js
+// Input
+// prettier-ignore
+'use strict';
+
+function foo() {
+// prettier-ignore
+"use strict";;
+}
+
+// Prettier stable
+// prettier-ignore
+'use strict';;
+
+function foo() {
+  // prettier-ignore
+  "use strict";;
+}
+
+// Prettier master
+// prettier-ignore
+'use strict';
+
+function foo() {
+  // prettier-ignore
+  "use strict";
+}
+```
